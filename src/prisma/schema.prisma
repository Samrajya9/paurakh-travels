generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}


enum UserType {
  ADMIN
  CUSTOMER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  userType  UserType @default(CUSTOMER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}