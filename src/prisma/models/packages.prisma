model Package {
    id   String @id @default(cuid())
    slug String @unique
    name String

    htmlOverview String? @map("html_overview") @db.Text

    itineraries Itinerary[]
    faqs        PackageFaq[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("packages")
}
