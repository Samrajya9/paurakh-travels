model Package {
    id   String @id @default(cuid())
    slug String @unique
    name String

    description  String? @db.VarChar(300)
    htmlOverview String? @map("html_overview") @db.Text

    basePrice Decimal @map("base_price") @db.Decimal(10, 2)

    difficultyId String     @map("difficulty_id")
    difficulty   Difficulty @relation(fields: [difficultyId], references: [id], onDelete: Restrict)

    itineraries    Itinerary[]
    faqs           PackageFaq[]
    groupDiscounts PackageGroupDiscount[]

    likes UserPackageLike[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("packages")
}
